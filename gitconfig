[includeIf "gitdir:**/github/"]
  path = ~/config.github

[includeIf "gitdir:**/gitlab/"]
  path = ~/config.gitlab
[commit]
	gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential]
	helper = store
[pull]
	rebase = true
[net]
	git-fetch-with-cli = false
[safe]
	directory = /home/mkurzyns/framework-test/Nanoflow
